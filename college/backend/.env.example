# InsightRural Environment Configuration
# Copy this file to .env and fill in your values

# Sarvam AI API Key (Required for chat and generation features)
# Get your API key from the Sarvam AI dashboard
SARVAM_API_KEY=your-sarvam-api-key-here

# Optional: Change the model (default: sarvam-m)
# SARVAM_MODEL=sarvam-m
